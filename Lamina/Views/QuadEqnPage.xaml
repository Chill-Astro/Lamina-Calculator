<Page
    x:Class="Lamina.Views.QuadEqnPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{x:Null}"
    mc:Ignorable="d">

    <Grid Background="Transparent">
        <StackPanel
            Margin="0,0,0,0"
            HorizontalAlignment="Center"
            VerticalAlignment="Top"
            Spacing="12">

            <InfoBar
                Title="Formula"
                IsClosable="False"
                IsIconVisible="True"
                IsOpen="True"
                Message="x = [-b ± √(b² - 4ac)] / 2a"
                Severity="Informational" />

            <NumberBox
                x:Name="CoefficientANumberBox"
                Width="300"
                Header="First Coefficient (a)"
                PlaceholderText="0.00"
                SpinButtonPlacementMode="Compact" />

            <NumberBox
                x:Name="CoefficientBNumberBox"
                Width="300"
                Header="Second Coefficient (b)"
                PlaceholderText="0.00"
                SpinButtonPlacementMode="Compact" />

            <NumberBox
                x:Name="CoefficientCNumberBox"
                Width="300"
                Header="Third Coefficient (c)"
                PlaceholderText="0.00"
                SpinButtonPlacementMode="Compact" />

            <Button
                x:Name="CalculateRootsButton"
                Margin="0,15,0,0"
                HorizontalAlignment="Center"
                Click="CalculateRootsButton_Click"
                Content="Calculate"
                Style="{StaticResource AccentButtonStyle}">
                <Button.KeyboardAccelerators>
                    <KeyboardAccelerator Key="Enter" />
                </Button.KeyboardAccelerators>
            </Button>
        </StackPanel>

        <ContentDialog
            x:Name="ResultDialog"
            Title="Result"
            DefaultButton="Primary"
            PrimaryButtonText="Close">
            <StackPanel Margin="0,10,0,0" Spacing="4">

                <TextBlock
                    x:Name="ResultLabel"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Style="{StaticResource CaptionTextBlockStyle}" />

                <Grid x:Name="ResultValueContainer">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock
                        x:Name="ResultValueText"
                        Grid.Column="0"
                        MaxWidth="400"
                        VerticalAlignment="Center"
                        FontSize="28"
                        FontWeight="SemiBold"
                        TextTrimming="CharacterEllipsis"
                        TextWrapping="Wrap" />

                    <Button
                        x:Name="CopyButton"
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        Click="CopyButton_Click"
                        Style="{StaticResource SubtleButtonStyle}"
                        ToolTipService.ToolTip="Copy to clipboard">
                        <FontIcon Glyph="&#xE8C8;" />
                    </Button>
                </Grid>
            </StackPanel>
        </ContentDialog>
    </Grid>
</Page>