<Page
    x:Class="Lamina.Views.FinanceCalculatorPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent">

    <!--  Scriptie  -->

    <Grid Background="Transparent">
        <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Hidden">

            <StackPanel
                Margin="0,20,0,20"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Spacing="12">

                <!--  Dropdown Menu for Simplicity  -->
                <ComboBox
                    x:Name="ComboBox"
                    Width="300"
                    Header="Investment Type"
                    SelectedIndex="0"
                    SelectionChanged="ComboBox_SelectionChanged">
                    <ComboBoxItem Content="Simple Interest" />
                    <ComboBoxItem Content="Compound Interest" />
                    <ComboBoxItem Content="Recurring Deposit" />
                </ComboBox>

                <!--  Formula Bar (Variable)  -->
                <InfoBar
                    x:Name="FormulaInfoBar"
                    Title="Formula"
                    IsClosable="False"
                    IsOpen="True"
                    Severity="Informational" />

                <NumberBox
                    x:Name="InputA"
                    Width="300"
                    SpinButtonPlacementMode="Compact"
                    Visibility="Collapsed" />
                <NumberBox
                    x:Name="InputB"
                    Width="300"
                    SpinButtonPlacementMode="Compact"
                    Visibility="Collapsed" />
                <NumberBox
                    x:Name="InputC"
                    Width="300"
                    SpinButtonPlacementMode="Compact"
                    Visibility="Collapsed" />
                <NumberBox
                    x:Name="InputD"
                    Width="300"
                    SpinButtonPlacementMode="Compact"
                    Visibility="Collapsed" />

                <Button
                    x:Name="CalculateButton"
                    Margin="0,15,0,0"
                    HorizontalAlignment="Center"
                    Click="CalculateButton_Click"
                    Content="Calculate"
                    Style="{StaticResource AccentButtonStyle}">
                    <Button.KeyboardAccelerators>
                        <KeyboardAccelerator Key="Enter" />
                    </Button.KeyboardAccelerators>
                </Button>
            </StackPanel>
        </ScrollViewer>

        <!--  Popup Box  -->
        <ContentDialog
            x:Name="ResultDialog"
            Title="Result"
            DefaultButton="Primary"
            PrimaryButtonText="Close">
            <StackPanel Margin="0,10,0,0" Spacing="8">
                <TextBlock
                    x:Name="ResultLabel"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Style="{StaticResource CaptionTextBlockStyle}" />
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        x:Name="ResultValueText"
                        Grid.Column="0"
                        VerticalAlignment="Center"
                        FontSize="28"
                        FontWeight="Bold"
                        TextWrapping="WrapWholeWords" />
                    <Button
                        x:Name="CopyButton"
                        Grid.Column="1"
                        Width="40"
                        Height="40"
                        VerticalAlignment="Center"
                        Click="CopyButton_Click"
                        Style="{StaticResource SubtleButtonStyle}">
                        <FontIcon FontSize="16" Glyph="&#xE8C8;" />
                    </Button>
                </Grid>
            </StackPanel>
        </ContentDialog>
    </Grid>
</Page>