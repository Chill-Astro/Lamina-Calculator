<Page
    x:Class="Lamina.Views.BaseConverterPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent">

    <Grid Background="Transparent">
        <StackPanel
            Margin="0,0,0,0"
            HorizontalAlignment="Center"
            VerticalAlignment="Top"
            Spacing="12">

            <InfoBar
                Title="Formula"
                IsClosable="False"
                IsIconVisible="True"
                IsOpen="True"
                Message="N₁₀ = Σ (dᵢ × bⁱ)&#10;Nᵦ = N₁₀ mod b"
                Severity="Informational" />

            <TextBox
                x:Name="InputTextBox"
                Width="300"
                Header="Input Number"
                PlaceholderText="e.g. 1010 or FF" />

            <ComboBox
                x:Name="FromBaseComboBox"
                Width="300"
                Header="From Base"
                SelectedIndex="1">
                <ComboBoxItem Content="Binary (2)" Tag="2" />
                <ComboBoxItem Content="Decimal (10)" Tag="10" />
                <ComboBoxItem Content="Hexadecimal (16)" Tag="16" />
                <ComboBoxItem Content="Octal (8)" Tag="8" />
            </ComboBox>

            <ComboBox
                x:Name="ToBaseComboBox"
                Width="300"
                Header="To Base"
                SelectedIndex="0">
                <ComboBoxItem Content="Binary (2)" Tag="2" />
                <ComboBoxItem Content="Decimal (10)" Tag="10" />
                <ComboBoxItem Content="Hexadecimal (16)" Tag="16" />
                <ComboBoxItem Content="Octal (8)" Tag="8" />
            </ComboBox>

            <Button
                x:Name="ConvertButton"
                Margin="0,15,0,0"
                HorizontalAlignment="Center"
                Click="ConvertButton_Click"
                Content="Convert"
                Style="{StaticResource AccentButtonStyle}">
                <Button.KeyboardAccelerators>
                    <KeyboardAccelerator Key="Enter" />
                </Button.KeyboardAccelerators>
            </Button>
        </StackPanel>

        <ContentDialog
            x:Name="ResultDialog"
            Title="Result"
            DefaultButton="Primary"
            PrimaryButtonText="Close">
            <StackPanel Margin="0,10,0,0" Spacing="8">
                <TextBlock
                    x:Name="ResultLabel"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Style="{StaticResource CaptionTextBlockStyle}" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        x:Name="ResultValueText"
                        Grid.Column="0"
                        MaxWidth="400"
                        VerticalAlignment="Center"
                        FontSize="28"
                        FontWeight="SemiBold"
                        TextTrimming="CharacterEllipsis"
                        TextWrapping="Wrap" />
                    <Button
                        x:Name="CopyButton"
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        Click="CopyButton_Click"
                        Style="{StaticResource SubtleButtonStyle}">
                        <FontIcon Glyph="&#xE8C8;" />
                    </Button>
                </Grid>
            </StackPanel>
        </ContentDialog>
    </Grid>
</Page>