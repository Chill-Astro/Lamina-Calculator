<Page
    x:Class="Lamina.Views.DateCalculatorPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Hidden">
        <StackPanel
            Margin="0,0,0,0"
            HorizontalAlignment="Center"
            Spacing="24">

            <ComboBox
                x:Name="ModeSelector"
                Width="300"
                Background="Transparent"
                BorderThickness="0"
                SelectedIndex="0"
                SelectionChanged="ModeSelector_SelectionChanged">
                <ComboBoxItem Content="Difference between dates" />
                <ComboBoxItem Content="Add or subtract days" />
            </ComboBox>

            <StackPanel x:Name="DifferenceSection" Spacing="16">
                <CalendarDatePicker
                    x:Name="FromDateDiff"
                    Width="300"
                    HorizontalAlignment="Left"
                    Header="From" />
                <CalendarDatePicker
                    x:Name="ToDateDiff"
                    Width="300"
                    HorizontalAlignment="Left"
                    Header="To" />

                <StackPanel Margin="0,12,0,0" Spacing="4">
                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Text="Difference" />
                    <TextBlock
                        x:Name="DiffResultText"
                        FontSize="20"
                        FontWeight="SemiBold"
                        Text="Same dates" />
                </StackPanel>
            </StackPanel>

            <StackPanel
                x:Name="AddSubtractSection"
                Spacing="16"
                Visibility="Collapsed">
                <CalendarDatePicker
                    x:Name="StartDateAdd"
                    Width="300"
                    HorizontalAlignment="Left"
                    Header="From" />

                <StackPanel
                    Margin="0,0,0,0"
                    Orientation="Horizontal"
                    Spacing="20">
                    <RadioButton
                        x:Name="AddRadio"
                        Checked="LiveUpdateAdd"
                        Content="Add"
                        IsChecked="True" />
                    <RadioButton
                        x:Name="SubtractRadio"
                        Checked="LiveUpdateAdd"
                        Content="Subtract" />
                </StackPanel>

                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <NumberBox
                        x:Name="YearsInput"
                        Header="Years"
                        SpinButtonPlacementMode="Compact"
                        ValueChanged="LiveUpdateAdd"
                        Value="0" />
                    <NumberBox
                        x:Name="MonthsInput"
                        Grid.Column="1"
                        Header="Months"
                        SpinButtonPlacementMode="Compact"
                        ValueChanged="LiveUpdateAdd"
                        Value="0" />
                    <NumberBox
                        x:Name="DaysInput"
                        Grid.Column="2"
                        Header="Days"
                        SpinButtonPlacementMode="Compact"
                        ValueChanged="LiveUpdateAdd"
                        Value="0" />
                </Grid>

                <StackPanel Margin="0,12,0,0" Spacing="4">
                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Text="Date" />
                    <TextBlock
                        x:Name="AddResultText"
                        FontSize="20"
                        FontWeight="SemiBold"
                        Text="---" />
                </StackPanel>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>