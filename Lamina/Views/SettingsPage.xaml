<Page
    x:Class="Lamina.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:xaml="using:Microsoft.UI.Xaml"
    Background="Transparent">

    <ScrollViewer
        IsVerticalRailEnabled="True"
        VerticalScrollBarVisibility="Hidden"
        VerticalScrollMode="Auto">

        <Grid HorizontalAlignment="Stretch">
            <StackPanel
                MaxWidth="380"
                Padding="20"
                HorizontalAlignment="Stretch"
                Spacing="24">

                <StackPanel HorizontalAlignment="Center" Spacing="8">
                    <Image
                        Width="80"
                        Height="80"
                        Margin="0,0,0,10"
                        Source="ms-appx:///Assets/WindowIcon.ico" />

                    <TextBlock
                        HorizontalAlignment="Center"
                        FontSize="32"
                        FontWeight="SemiBold"
                        Text="Lamina ✦" />

                    <TextBlock
                        HorizontalAlignment="Center"
                        FontFamily="ms-appx:///Assets/Fonts/AlexBrush-Regular.ttf#Alex Brush"
                        FontSize="30"
                        Opacity="0.8"
                        Text="“Math on a Sheet of Glass!”" />

                    <HyperlinkButton
                        Padding="4,2"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Command="{x:Bind ViewModel.OpenProfileCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                FontSize="14"
                                Opacity="0.8"
                                Text="Developer : " />
                            <TextBlock
                                FontSize="14"
                                FontWeight="Medium"
                                Foreground="{ThemeResource AccentButtonBackground}"
                                Text=" Chill-Astro Software" />
                        </StackPanel>
                    </HyperlinkButton>

                    <Button
                        Padding="4,2"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        BorderThickness="0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                FontSize="14"
                                Opacity="0.8"
                                Text="Version : " />
                            <TextBlock
                                FontSize="14"
                                FontWeight="Medium"
                                Foreground="{ThemeResource AccentButtonBackground}"
                                Text="{x:Bind ViewModel.AppVersionText, Mode=OneWay}" />
                        </StackPanel>
                    </Button>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <Button
                            Grid.Column="0"
                            Height="40"
                            HorizontalAlignment="Stretch"
                            Command="{x:Bind ViewModel.OpenRepoCommand}"
                            Content="Repository"
                            CornerRadius="8"
                            Style="{StaticResource AccentButtonStyle}" />

                        <Button
                            Grid.Column="1"
                            Height="40"
                            HorizontalAlignment="Stretch"
                            Command="{x:Bind ViewModel.ShowLicenseCommand}"
                            Content="MIT License"
                            CornerRadius="8"
                            Style="{StaticResource AccentButtonStyle}" />
                    </Grid>

                    <Grid HorizontalAlignment="Stretch">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border
                            Grid.Row="0"
                            Margin="0,0,0,4"
                            Padding="16"
                            HorizontalAlignment="Stretch"
                            Background="{ThemeResource CardBackgroundFillColorDefault}"
                            BorderBrush="{ThemeResource CardStrokeColorDefault}"
                            BorderThickness="1"
                            CornerRadius="8">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock VerticalAlignment="Center" Text="Theme" />
                                <ComboBox
                                    Grid.Column="1"
                                    MinWidth="150"
                                    SelectedIndex="{x:Bind ViewModel.SelectedThemeIndex, Mode=TwoWay}">
                                    <ComboBoxItem Content="System" />
                                    <ComboBoxItem Content="Light" />
                                    <ComboBoxItem Content="Dark" />
                                </ComboBox>
                            </Grid>
                        </Border>

                        <Border
                            Grid.Row="1"
                            Padding="16"
                            HorizontalAlignment="Stretch"
                            Background="{ThemeResource CardBackgroundFillColorDefault}"
                            BorderBrush="{ThemeResource CardStrokeColorDefault}"
                            BorderThickness="1"
                            CornerRadius="8">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock VerticalAlignment="Center" Text="Backdrop" />
                                <ComboBox
                                    Grid.Column="1"
                                    MinWidth="150"
                                    SelectedIndex="{x:Bind ViewModel.SelectedBackdropIndex, Mode=TwoWay}">
                                    <ComboBoxItem Content="Mica Alt" />
                                    <ComboBoxItem Content="Mica" />
                                    <ComboBoxItem Content="Acrylic" />
                                </ComboBox>
                            </Grid>
                        </Border>
                    </Grid>

                    <Border
                        Padding="16"
                        HorizontalAlignment="Stretch"
                        Background="{ThemeResource CardBackgroundFillColorDefault}"
                        BorderBrush="{ThemeResource CardStrokeColorDefault}"
                        BorderThickness="1"
                        CornerRadius="8">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock VerticalAlignment="Center" Text="Splash Screen" />

                            <ToggleSwitch
                                Grid.Column="1"
                                MinWidth="0"
                                Margin="0,-6,0,-6"
                                VerticalAlignment="Center"
                                IsOn="{x:Bind ViewModel.IsSplashEnabled, Mode=TwoWay}"
                                OffContent=""
                                OnContent="" />
                        </Grid>
                    </Border>

                    <StackPanel Margin="0,10,0,20" Spacing="12">
                        <Button
                            Padding="30,10"
                            HorizontalAlignment="Center"
                            Command="{x:Bind ViewModel.CheckForUpdatesCommand}"
                            Content="Check for Updates"
                            CornerRadius="5"
                            Style="{StaticResource AccentButtonStyle}" />
                        <TextBlock
                            HorizontalAlignment="Center"
                            FontSize="12"
                            Opacity="0.5"
                            Text="Made with 💖 by Chill-Astro" />
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>