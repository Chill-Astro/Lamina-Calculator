<Page
    x:Class="Lamina.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:xaml="using:Microsoft.UI.Xaml"
    Background="Transparent">

    <!--  This Page has Undergone a MAJOR Revamp in v11.26100.13.0. Inspired from FOSS Root Checker!  -->

    <ScrollViewer
        IsVerticalRailEnabled="True"
        VerticalScrollBarVisibility="Hidden"
        VerticalScrollMode="Auto">

        <Grid HorizontalAlignment="Stretch">
            <StackPanel
                MaxWidth="380"
                Padding="20"
                HorizontalAlignment="Stretch"
                Spacing="24">

                <StackPanel HorizontalAlignment="Center" Spacing="8">
                    <Image
                        Width="80"
                        Height="80"
                        Margin="0,0,0,10"
                        Source="ms-appx:///Assets/WindowIcon.ico" />

                    <TextBlock
                        HorizontalAlignment="Center"
                        FontFamily="ms-appx:///Assets/Fonts/AlexBrush-Regular.ttf#Alex Brush"
                        FontSize="50"
                        Text="Lamina ✦" />

                    <!--  Tagline  -->
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontFamily="ms-appx:///Assets/Fonts/AlexBrush-Regular.ttf#Alex Brush"
                        FontSize="30"
                        Opacity="0.6"
                        Text="“Math on a Sheet of Glass!”" />

                    <!--  Github Profile Ad Sorry :)  -->
                    <HyperlinkButton
                        Padding="4,2"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Command="{x:Bind ViewModel.OpenProfileCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                FontSize="14"
                                Opacity="0.8"
                                Text="Developer : " />
                            <TextBlock
                                FontSize="14"
                                FontWeight="Medium"
                                Foreground="{ThemeResource AccentButtonBackground}"
                                Text=" Chill-Astro Software" />
                        </StackPanel>
                    </HyperlinkButton>

                    <Button
                        Padding="4,2"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        BorderThickness="0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                FontSize="14"
                                Opacity="0.8"
                                Text="Version : " />
                            <TextBlock
                                FontSize="14"
                                FontWeight="Medium"
                                Foreground="{ThemeResource AccentButtonBackground}"
                                Text="{x:Bind ViewModel.AppVersionText, Mode=OneWay}" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                    <Button
                        Grid.Column="0"
                        Height="40"
                        HorizontalAlignment="Stretch"
                        Command="{x:Bind ViewModel.OpenRepoCommand}"
                        Content="Repository"
                        CornerRadius="8"
                        Style="{StaticResource AccentButtonStyle}" />

                    <Button
                        Grid.Column="1"
                        Height="40"
                        HorizontalAlignment="Stretch"
                        Command="{x:Bind ViewModel.ShowLicenseCommand}"
                        Content="MIT License"
                        CornerRadius="8"
                        Style="{StaticResource AccentButtonStyle}" />
                </Grid>

                <StackPanel HorizontalAlignment="Stretch" Spacing="4">

                    <!--  Theme Setting  -->
                    <Border
                        Padding="16"
                        HorizontalAlignment="Stretch"
                        Background="{ThemeResource CardBackgroundFillColorDefault}"
                        BorderBrush="{ThemeResource CardStrokeColorDefault}"
                        BorderThickness="1"
                        CornerRadius="8">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <FontIcon
                                Margin="0,0,12,0"
                                VerticalAlignment="Center"
                                FontSize="16"
                                Glyph="&#xE790;" />
                            <TextBlock
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                Text="Theme" />
                            <ComboBox
                                Grid.Column="2"
                                MinWidth="150"
                                SelectedIndex="{x:Bind ViewModel.SelectedThemeIndex, Mode=TwoWay}">
                                <ComboBoxItem Content="System" />
                                <ComboBoxItem Content="Light" />
                                <ComboBoxItem Content="Dark" />
                            </ComboBox>
                        </Grid>
                    </Border>

                    <!--  Backdrop Setting  -->
                    <Border
                        Padding="16"
                        HorizontalAlignment="Stretch"
                        Background="{ThemeResource CardBackgroundFillColorDefault}"
                        BorderBrush="{ThemeResource CardStrokeColorDefault}"
                        BorderThickness="1"
                        CornerRadius="8">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <FontIcon
                                Margin="0,0,12,0"
                                VerticalAlignment="Center"
                                FontSize="16"
                                Glyph="&#xEB42;" />
                            <TextBlock
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                Text="Backdrop" />
                            <ComboBox
                                Grid.Column="2"
                                MinWidth="150"
                                SelectedIndex="{x:Bind ViewModel.SelectedBackdropIndex, Mode=TwoWay}">
                                <ComboBoxItem Content="Mica Alt" />
                                <ComboBoxItem Content="Mica" />
                                <ComboBoxItem Content="Acrylic" />
                            </ComboBox>
                        </Grid>
                    </Border>

                    <Border
                        Padding="16"
                        HorizontalAlignment="Stretch"
                        Background="{ThemeResource CardBackgroundFillColorDefault}"
                        BorderBrush="{ThemeResource CardStrokeColorDefault}"
                        BorderThickness="1"
                        CornerRadius="8">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <FontIcon
                                Margin="0,0,12,0"
                                VerticalAlignment="Center"
                                FontSize="16"
                                Glyph="&#xE78B;" />
                            <TextBlock
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                Text="Splash Screen" />
                            <ToggleSwitch
                                Grid.Column="2"
                                MinWidth="0"
                                Margin="0,-6,0,-6"
                                VerticalAlignment="Center"
                                IsOn="{x:Bind ViewModel.IsSplashEnabled, Mode=TwoWay}"
                                OffContent=""
                                OnContent="" />
                        </Grid>
                    </Border>
                </StackPanel>

                <StackPanel Margin="0,10,0,20" Spacing="12">
                    <Button
                        Padding="30,10"
                        HorizontalAlignment="Center"
                        Command="{x:Bind ViewModel.CheckForUpdatesCommand}"
                        Content="Check for Updates"
                        CornerRadius="8"
                        Style="{StaticResource AccentButtonStyle}" />

                    <!--  Please Star my Repo! :)  -->
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontSize="12"
                        Opacity="0.5"
                        Text="Made with 💖 by Chill-Astro" />
                </StackPanel>

            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>