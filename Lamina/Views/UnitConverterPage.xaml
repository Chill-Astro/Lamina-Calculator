<Page
    x:Class="Lamina.Views.UnitConverterPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="Transparent"
    mc:Ignorable="d">

    <Grid Background="Transparent">
        <ScrollViewer VerticalScrollBarVisibility="Hidden">
            <StackPanel
                Margin="0,0,0,0"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Spacing="24">

                <Border
                    Width="300"
                    Padding="24"
                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="12">

                    <StackPanel Spacing="20">
                        <ComboBox
                            x:Name="CategoryComboBox"
                            HorizontalAlignment="Stretch"
                            Header="Category"
                            SelectionChanged="CategoryComboBox_SelectionChanged">
                            <ComboBoxItem Content="Length" />
                            <ComboBoxItem Content="Weight (Mass)" />
                            <ComboBoxItem Content="Volume" />
                            <ComboBoxItem Content="Temperature" />
                            <ComboBoxItem Content="Area" />
                            <ComboBoxItem Content="Time" />
                            <ComboBoxItem Content="Speed" />
                            <ComboBoxItem Content="Energy" />
                            <ComboBoxItem Content="Pressure" />
                            <ComboBoxItem Content="Power" />
                            <ComboBoxItem Content="Data (Digital Storage)" />
                            <ComboBoxItem Content="Angle" />
                        </ComboBox>

                        <NumberBox
                            x:Name="ValueToConvertTextBox"
                            HorizontalAlignment="Stretch"
                            Header="Value"
                            PlaceholderText="Enter amount..."
                            SpinButtonPlacementMode="Compact"
                            Value="1.00" />

                        <Grid ColumnSpacing="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <ComboBox
                                x:Name="FromUnitComboBox"
                                Grid.Column="0"
                                HorizontalAlignment="Stretch"
                                Header="From" />

                            <Button
                                Grid.Column="1"
                                Margin="4,24,4,0"
                                VerticalAlignment="Top"
                                Background="Transparent"
                                BorderThickness="0"
                                Click="SwapButton_Click"
                                Content="&#xE8AB;"
                                FontFamily="Segoe Fluent Icons"
                                Style="{StaticResource SubtleButtonStyle}">
                                <ToolTipService.ToolTip>
                                    <ToolTip Content="Swap units" />
                                </ToolTipService.ToolTip>
                            </Button>

                            <ComboBox
                                x:Name="ToUnitComboBox"
                                Grid.Column="2"
                                HorizontalAlignment="Stretch"
                                Header="To" />
                        </Grid>

                        <Button
                            x:Name="ConvertButton"
                            Height="40"
                            HorizontalAlignment="Stretch"
                            Click="ConvertButton_Click"
                            Content="Convert"
                            Style="{StaticResource AccentButtonStyle}" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <ContentDialog
            x:Name="ResultDialog"
            Title="Conversion Result"
            DefaultButton="Primary"
            PrimaryButtonText="Close">
            <StackPanel Margin="0,10,0,0" Spacing="8">
                <TextBlock
                    x:Name="ResultLabel"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Style="{StaticResource CaptionTextBlockStyle}" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock
                        x:Name="ResultValueText"
                        Grid.Column="0"
                        MaxWidth="320"
                        VerticalAlignment="Center"
                        FontSize="24"
                        FontWeight="SemiBold"
                        TextTrimming="CharacterEllipsis"
                        TextWrapping="Wrap" />

                    <Button
                        x:Name="CopyButton"
                        Grid.Column="1"
                        Margin="12,0,0,0"
                        VerticalAlignment="Center"
                        Click="CopyButton_Click"
                        Style="{StaticResource SubtleButtonStyle}">
                        <FontIcon Glyph="&#xE8C8;" />
                        <ToolTipService.ToolTip>
                            <ToolTip Content="Copy to clipboard" />
                        </ToolTipService.ToolTip>
                    </Button>
                </Grid>
            </StackPanel>
        </ContentDialog>
    </Grid>
</Page>