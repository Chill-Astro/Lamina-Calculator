<Page
    x:Class="Lamina.Views.DyNamoMangerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Lamina.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="Transparent"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Hidden">
        <Grid HorizontalAlignment="Stretch">
            <StackPanel
                MaxWidth="400"
                Padding="0"
                HorizontalAlignment="Center"
                Spacing="24">

                <StackPanel HorizontalAlignment="Center" Spacing="0">
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontFamily="ms-appx:///Assets/Fonts/AlexBrush-Regular.ttf#Alex Brush"
                        FontSize="54"
                        Text="Lamina ✦" />
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontFamily="ms-appx:///Assets/Fonts/AlexBrush-Regular.ttf#Alex Brush"
                        FontSize="20"
                        FontWeight="SemiBold"
                        Opacity="0.5"
                        Text="Dynamo Scriptie Loader" />
                    <StackPanel
                        Margin="0,16,0,0"
                        HorizontalAlignment="Center"
                        Orientation="Horizontal"
                        Spacing="8">
                        <Button
                            Padding="24,8"
                            Click="Download_Click"
                            Content="Download"
                            CornerRadius="8"
                            Style="{StaticResource AccentButtonStyle}" />

                        <Button
                            Padding="24,8"
                            Click="Contribute_Click"
                            Content="Contribute"
                            CornerRadius="8"
                            Style="{StaticResource AccentButtonStyle}" />
                    </StackPanel>
                </StackPanel>

                <TextBlock
                    x:Name="EmptyStateText"
                    HorizontalAlignment="Center"
                    FontSize="16"
                    Opacity="0.4"
                    Text="No Scripties? Contribute Some!"
                    Visibility="Collapsed" />

                <ItemsControl x:Name="ScriptieList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="local:LaminaScript">
                            <Border
                                Margin="0,0,0,12"
                                Padding="16"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                                <StackPanel Spacing="4">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBlock
                                            FontSize="16"
                                            FontWeight="Bold"
                                            Text="{x:Bind Metadata.Name}" />
                                        <StackPanel
                                            Grid.Column="1"
                                            Orientation="Horizontal"
                                            Spacing="8">
                                            <Button
                                                Width="32"
                                                Height="32"
                                                Padding="0"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Click="Repo_Click"
                                                Content="&#xE71B;"
                                                FontFamily="Segoe MDL2 Assets"
                                                Tag="{x:Bind Metadata.Repo}"
                                                ToolTipService.ToolTip="View Repository" />
                                            <Button
                                                Width="32"
                                                Height="32"
                                                Padding="0"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Click="Delete_Click"
                                                Content="&#xE74D;"
                                                FontFamily="Segoe MDL2 Assets"
                                                Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                                ToolTipService.ToolTip="Remove Scriptie" />
                                        </StackPanel>
                                    </Grid>
                                    <TextBlock FontSize="12" Opacity="0.6">
                                        <Run FontWeight="SemiBold" Text="{x:Bind Metadata.Author}" />
                                        <Run Text=" • v" />
                                        <Run Text="{x:Bind Metadata.Version}" />
                                    </TextBlock>
                                    <TextBlock
                                        Margin="0,8,0,0"
                                        FontSize="13"
                                        Opacity="0.8"
                                        Text="{x:Bind Metadata.Description}"
                                        TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>