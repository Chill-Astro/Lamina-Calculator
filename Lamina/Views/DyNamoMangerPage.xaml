<Page
    x:Class="Lamina.Views.DyNamoMangerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Lamina.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="Transparent"
    mc:Ignorable="d">

    <!--  Dynamo Scripties Manager  -->

    <ScrollViewer
        IsScrollInertiaEnabled="True"
        IsVerticalRailEnabled="True"
        VerticalScrollBarVisibility="Hidden"
        VerticalScrollMode="Auto">

        <Grid Padding="0,32,0,64" HorizontalAlignment="Stretch">
            <StackPanel
                MaxWidth="400"
                HorizontalAlignment="Center"
                Spacing="28">

                <StackPanel HorizontalAlignment="Center" Spacing="0">
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontFamily="ms-appx:///Assets/Fonts/AlexBrush-Regular.ttf#Alex Brush"
                        FontSize="58"
                        Text="Lamina ✦" />
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontFamily="ms-appx:///Assets/Fonts/AlexBrush-Regular.ttf#Alex Brush"
                        FontSize="30"
                        FontWeight="SemiBold"
                        Opacity="0.5"
                        Text="Dynamo Scriptie Loader" />

                    <StackPanel
                        Margin="0,20,0,0"
                        HorizontalAlignment="Center"
                        Orientation="Horizontal"
                        Spacing="6">
                        <Button
                            Padding="20,8"
                            Click="Download_Click"
                            Content="Download"
                            CornerRadius="8"
                            Style="{StaticResource AccentButtonStyle}" />

                        <Button
                            Padding="20,8"
                            Click="Add_Click"
                            Content="Install"
                            CornerRadius="8"
                            Style="{StaticResource AccentButtonStyle}" />

                        <Button
                            Padding="20,8"
                            Click="Contribute_Click"
                            Content="Contribute"
                            CornerRadius="8"
                            Style="{StaticResource AccentButtonStyle}" />
                    </StackPanel>
                </StackPanel>

                <TextBlock
                    x:Name="EmptyStateText"
                    Margin="0,40,0,0"
                    HorizontalAlignment="Center"
                    FontSize="15"
                    FontStyle="Italic"
                    Opacity="0.4"
                    Text="Aww no Scripties? Contribute Some! :)"
                    Visibility="Collapsed" />

                <ItemsControl x:Name="ScriptieList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="local:LaminaScript">
                            <Border
                                Margin="0,0,0,16"
                                Padding="20"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="12">
                                <StackPanel Spacing="4">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBlock
                                            FontSize="18"
                                            FontWeight="Bold"
                                            Text="{x:Bind Metadata.Name}" />

                                        <StackPanel
                                            Grid.Column="1"
                                            Orientation="Horizontal"
                                            Spacing="0">
                                            <Button
                                                Width="36"
                                                Height="36"
                                                Padding="0"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Click="Repo_Click"
                                                Content="&#xE71B;"
                                                FontFamily="Segoe MDL2 Assets"
                                                Tag="{x:Bind Metadata.Repo}"
                                                ToolTipService.ToolTip="View Repository" />
                                            <Button
                                                Width="36"
                                                Height="36"
                                                Padding="0"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Click="Delete_Click"
                                                Content="&#xE74D;"
                                                FontFamily="Segoe MDL2 Assets"
                                                Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                                ToolTipService.ToolTip="Remove" />
                                        </StackPanel>
                                    </Grid>

                                    <TextBlock FontSize="13" Opacity="0.5">
                                        <Run FontWeight="SemiBold" Text="{x:Bind Metadata.Author}" />
                                        <Run Text=" • v" />
                                        <Run Text="{x:Bind Metadata.Version}" />
                                    </TextBlock>

                                    <TextBlock
                                        Margin="0,10,0,0"
                                        FontSize="14"
                                        Opacity="0.85"
                                        Text="{x:Bind Metadata.Description}"
                                        TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>