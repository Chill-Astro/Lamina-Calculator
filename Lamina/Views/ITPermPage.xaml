<Page
    x:Class="Lamina.Views.ITPermPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Grid Background="Transparent">
        <StackPanel
            Margin="0,20,0,0"
            HorizontalAlignment="Center"
            VerticalAlignment="Top"
            Spacing="8">
            <TextBlock Style="{StaticResource BaseTextBlockStyle}" Text="Enter Eq. Side's Length [a] :" />
            <TextBox
                x:Name="EqualSideTextBox"
                Width="200"
                HorizontalAlignment="Stretch" />
            <TextBlock Style="{StaticResource BaseTextBlockStyle}" Text="Enter Base's Length [b] :" />
            <TextBox
                x:Name="NonEqualSideTextBox"
                Width="200"
                HorizontalAlignment="Stretch" />
            <Button
                Margin="0,15,0,0"
                HorizontalAlignment="Center"
                Click="CalculateButton_Click"
                Content="Calculate"
                Style="{StaticResource AccentButtonStyle}" />
            <TextBlock
                x:Name="ResultTextBlock"
                HorizontalAlignment="Center"
                FontSize="12"
                FontWeight="SemiBold"
                IsTextSelectionEnabled="True"
                Style="{StaticResource BodyTextBlockStyle}"
                Text="OUTPUT AREA" />
        </StackPanel>
    </Grid>
</Page>