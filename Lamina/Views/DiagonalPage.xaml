<Page
    x:Class="Lamina.Views.DiagonalPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{x:Null}">

    <!--  Scriptie  -->

    <Grid Background="Transparent">
        <StackPanel
            Margin="0,0,0,0"
            HorizontalAlignment="Center"
            VerticalAlignment="Top"
            Spacing="12">

            <!--  Dropdown Menu for Simplicity  -->
            <ComboBox
                x:Name="ShapeComboBox"
                Width="300"
                SelectedIndex="0"
                SelectionChanged="ShapeComboBox_SelectionChanged">
                <ComboBoxItem Content="Square" />
                <ComboBoxItem Content="Rectangle" />
                <ComboBoxItem Content="Cube" />
                <ComboBoxItem Content="Cuboid" />
            </ComboBox>

            <!--  Formula Bar (Variable)  -->
            <InfoBar
                x:Name="FormulaInfoBar"
                Title="Formula"
                IsClosable="False"
                IsOpen="True"
                Severity="Informational" />

            <NumberBox
                x:Name="InputA"
                Width="300"
                SpinButtonPlacementMode="Compact"
                Visibility="Collapsed" />
            <NumberBox
                x:Name="InputB"
                Width="300"
                SpinButtonPlacementMode="Compact"
                Visibility="Collapsed" />
            <NumberBox
                x:Name="InputC"
                Width="300"
                SpinButtonPlacementMode="Compact"
                Visibility="Collapsed" />

            <Button
                x:Name="CalculateButton"
                Margin="0,15,0,0"
                HorizontalAlignment="Center"
                Click="CalculateButton_Click"
                Content="Calculate"
                Style="{StaticResource AccentButtonStyle}">
                <Button.KeyboardAccelerators>
                    <KeyboardAccelerator Key="Enter" />
                </Button.KeyboardAccelerators>
            </Button>
        </StackPanel>

        <!--  Popup Box  -->
        <ContentDialog
            x:Name="ResultDialog"
            Title="Result"
            DefaultButton="Primary"
            PrimaryButtonText="Close">
            <StackPanel Margin="0,10,0,0" Spacing="8">
                <TextBlock
                    x:Name="ResultLabel"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Style="{StaticResource CaptionTextBlockStyle}" />
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        x:Name="ResultValueText"
                        Grid.Column="0"
                        VerticalAlignment="Center"
                        FontSize="28"
                        FontWeight="Bold"
                        TextWrapping="WrapWholeWords" />
                    <Button
                        Grid.Column="1"
                        Width="40"
                        Height="40"
                        VerticalAlignment="Center"
                        Click="CopyButton_Click"
                        Style="{StaticResource SubtleButtonStyle}">
                        <FontIcon FontSize="16" Glyph="&#xE8C8;" />
                    </Button>
                </Grid>
            </StackPanel>
        </ContentDialog>
    </Grid>
</Page>