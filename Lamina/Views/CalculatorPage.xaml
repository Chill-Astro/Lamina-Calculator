<Page
    x:Class="Lamina.Views.CalculatorPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{x:Null}"
    IsTabStop="True"
    Loaded="CalculatorPage_Loaded"
    PreviewKeyDown="CalculatorPage_PreviewKeyDown"
    mc:Ignorable="d">

    <Page.Resources>
        <Style x:Key="CalculatorButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{ThemeResource ButtonBackground}" />
            <Setter Property="Foreground" Value="{ThemeResource ButtonForeground}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="8" />
            <Setter Property="Margin" Value="2" />
            <Setter Property="CornerRadius" Value="7" />
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
            <Setter Property="MinWidth" Value="55" />
            <Setter Property="MinHeight" Value="40" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="OuterBorder" Background="Transparent">
                            <Border
                                x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{TemplateBinding CornerRadius}">
                                <Border.RenderTransform>
                                    <ScaleTransform x:Name="ScaleTransform" ScaleX="1" ScaleY="1" />
                                </Border.RenderTransform>
                                <ContentPresenter
                                    x:Name="ContentPresenter"
                                    Margin="{TemplateBinding Padding}"
                                    HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                    VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                    Content="{TemplateBinding Content}"
                                    ContentTemplate="{TemplateBinding ContentTemplate}" />
                            </Border>
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal" />
                                    <VisualState x:Name="PointerOver">
                                        <Storyboard>
                                            <ColorAnimation
                                                Storyboard.TargetName="Border"
                                                Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                To="#20AAAAAA"
                                                Duration="0" />
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <Storyboard>
                                            <ColorAnimation
                                                Storyboard.TargetName="Border"
                                                Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                To="#30888888"
                                                Duration="0" />
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style
            x:Key="NumberButtonStyle"
            BasedOn="{StaticResource CalculatorButtonStyle}"
            TargetType="Button">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style
            x:Key="AccentButtonStyle"
            BasedOn="{StaticResource CalculatorButtonStyle}"
            TargetType="Button">
            <Setter Property="Background" Value="{ThemeResource AccentButtonBackground}" />
            <Setter Property="Foreground" Value="{ThemeResource AccentButtonForeground}" />
            <Setter Property="FontSize" Value="18" />
        </Style>
    </Page.Resources>

    <Grid>
        <Button
            Width="35"
            Height="35"
            Margin="0,-52,1,0"
            Padding="1"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Background="Transparent"
            BorderThickness="0"
            Click="HistoryButton_Click"
            Content="&#xe81c;"
            CornerRadius="3"
            FontFamily="Segoe Fluent Icons"
            FontSize="16">
            <Button.KeyboardAccelerators>
                <KeyboardAccelerator Key="H" Modifiers="Control" />
            </Button.KeyboardAccelerators>
        </Button>

        <Grid
            x:Name="ContentGrid"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            Background="Transparent"
            IsTabStop="False">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="100" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Viewbox
                Grid.Row="1"
                MaxHeight="120"
                Margin="0,-10,0,0"
                HorizontalAlignment="Right">
                <StackPanel HorizontalAlignment="Right" VerticalAlignment="Bottom">
                    <TextBlock
                        x:Name="OperationTextBlock"
                        Margin="12,-2,5,-5"
                        HorizontalAlignment="Right"
                        FontSize="7"
                        Opacity="0.7"
                        Text="{x:Bind ViewModel.OperationText, Mode=OneWay}"
                        TextAlignment="Right" />
                    <TextBlock
                        x:Name="DisplayTextBlock"
                        Margin="12,7,5,10"
                        HorizontalAlignment="Right"
                        FontSize="14"
                        FontWeight="SemiBold"
                        IsTextSelectionEnabled="True"
                        Text="{x:Bind ViewModel.DisplayText, Mode=OneWay}"
                        TextAlignment="Right" />
                </StackPanel>
            </Viewbox>
            <Grid Grid.Row="2" Margin="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Button
                    Grid.Row="0"
                    Grid.Column="0"
                    Command="{x:Bind ViewModel.PercentCommand}"
                    Content="&#xe94c;"
                    FontFamily="Segoe Fluent Icons"
                    Style="{StaticResource CalculatorButtonStyle}" />
                <Button
                    x:Name="BtnCE"
                    Grid.Row="0"
                    Grid.Column="1"
                    Command="{x:Bind ViewModel.ClearEntryCommand}"
                    Content="CE"
                    Style="{StaticResource CalculatorButtonStyle}" />
                <Button
                    x:Name="BtnC"
                    Grid.Row="0"
                    Grid.Column="2"
                    Command="{x:Bind ViewModel.ClearAllCommand}"
                    Content="C"
                    Style="{StaticResource CalculatorButtonStyle}" />
                <Button
                    x:Name="BtnBackspace"
                    Grid.Row="0"
                    Grid.Column="3"
                    Command="{x:Bind ViewModel.BackspaceCommand}"
                    Content="&#xe750;"
                    FontFamily="Segoe Fluent Icons"
                    Style="{StaticResource CalculatorButtonStyle}" />

                <Button
                    Grid.Row="1"
                    Grid.Column="0"
                    Command="{x:Bind ViewModel.SquareCommand}"
                    Content="𝑥²"
                    Style="{StaticResource CalculatorButtonStyle}" />
                <Button
                    Grid.Row="1"
                    Grid.Column="1"
                    Command="{x:Bind ViewModel.CubeRootCommand}"
                    Content="&#xe90c;"
                    FontFamily="/Assets/Fonts/Lamina_Fonts.ttf#Lamina_Fonts"
                    Style="{StaticResource CalculatorButtonStyle}" />
                <Button
                    Grid.Row="1"
                    Grid.Column="2"
                    Command="{x:Bind ViewModel.SquareRootCommand}"
                    Content="&#xe90b;"
                    FontFamily="/Assets/Fonts/Lamina_Fonts.ttf#Lamina_Fonts"
                    Style="{StaticResource CalculatorButtonStyle}" />
                <Button
                    x:Name="BtnDivide"
                    Grid.Row="1"
                    Grid.Column="3"
                    Command="{x:Bind ViewModel.SetOperatorCommand}"
                    CommandParameter="÷"
                    Content="&#xE94A;"
                    FontFamily="Segoe Fluent Icons"
                    Style="{StaticResource CalculatorButtonStyle}" />

                <Button
                    x:Name="Btn7"
                    Grid.Row="2"
                    Grid.Column="0"
                    Command="{x:Bind ViewModel.InputNumberCommand}"
                    CommandParameter="7"
                    Content="7"
                    Style="{StaticResource NumberButtonStyle}" />
                <Button
                    x:Name="Btn8"
                    Grid.Row="2"
                    Grid.Column="1"
                    Command="{x:Bind ViewModel.InputNumberCommand}"
                    CommandParameter="8"
                    Content="8"
                    Style="{StaticResource NumberButtonStyle}" />
                <Button
                    x:Name="Btn9"
                    Grid.Row="2"
                    Grid.Column="2"
                    Command="{x:Bind ViewModel.InputNumberCommand}"
                    CommandParameter="9"
                    Content="9"
                    Style="{StaticResource NumberButtonStyle}" />
                <Button
                    x:Name="BtnMultiply"
                    Grid.Row="2"
                    Grid.Column="3"
                    Command="{x:Bind ViewModel.SetOperatorCommand}"
                    CommandParameter="×"
                    Content="&#xE947;"
                    FontFamily="Segoe Fluent Icons"
                    Style="{StaticResource CalculatorButtonStyle}" />

                <Button
                    x:Name="Btn4"
                    Grid.Row="3"
                    Grid.Column="0"
                    Command="{x:Bind ViewModel.InputNumberCommand}"
                    CommandParameter="4"
                    Content="4"
                    Style="{StaticResource NumberButtonStyle}" />
                <Button
                    x:Name="Btn5"
                    Grid.Row="3"
                    Grid.Column="1"
                    Command="{x:Bind ViewModel.InputNumberCommand}"
                    CommandParameter="5"
                    Content="5"
                    Style="{StaticResource NumberButtonStyle}" />
                <Button
                    x:Name="Btn6"
                    Grid.Row="3"
                    Grid.Column="2"
                    Command="{x:Bind ViewModel.InputNumberCommand}"
                    CommandParameter="6"
                    Content="6"
                    Style="{StaticResource NumberButtonStyle}" />
                <Button
                    x:Name="BtnSubtract"
                    Grid.Row="3"
                    Grid.Column="3"
                    Command="{x:Bind ViewModel.SetOperatorCommand}"
                    CommandParameter="-"
                    Content="&#xE949;"
                    FontFamily="Segoe Fluent Icons"
                    Style="{StaticResource CalculatorButtonStyle}" />

                <Button
                    x:Name="Btn1"
                    Grid.Row="4"
                    Grid.Column="0"
                    Command="{x:Bind ViewModel.InputNumberCommand}"
                    CommandParameter="1"
                    Content="1"
                    Style="{StaticResource NumberButtonStyle}" />
                <Button
                    x:Name="Btn2"
                    Grid.Row="4"
                    Grid.Column="1"
                    Command="{x:Bind ViewModel.InputNumberCommand}"
                    CommandParameter="2"
                    Content="2"
                    Style="{StaticResource NumberButtonStyle}" />
                <Button
                    x:Name="Btn3"
                    Grid.Row="4"
                    Grid.Column="2"
                    Command="{x:Bind ViewModel.InputNumberCommand}"
                    CommandParameter="3"
                    Content="3"
                    Style="{StaticResource NumberButtonStyle}" />
                <Button
                    x:Name="BtnAdd"
                    Grid.Row="4"
                    Grid.Column="3"
                    Command="{x:Bind ViewModel.SetOperatorCommand}"
                    CommandParameter="+"
                    Content="&#xE948;"
                    FontFamily="Segoe Fluent Icons"
                    Style="{StaticResource CalculatorButtonStyle}" />

                <Button
                    Grid.Row="5"
                    Grid.Column="0"
                    Command="{x:Bind ViewModel.SetOperatorCommand}"
                    CommandParameter="^"
                    Content="&#xE90D;"
                    FontFamily="/Assets/Fonts/Lamina_Fonts.ttf#Lamina_Fonts"
                    Style="{StaticResource CalculatorButtonStyle}" />
                <Button
                    x:Name="Btn0"
                    Grid.Row="5"
                    Grid.Column="1"
                    Command="{x:Bind ViewModel.InputNumberCommand}"
                    CommandParameter="0"
                    Content="0"
                    Style="{StaticResource NumberButtonStyle}" />
                <Button
                    x:Name="BtnDecimal"
                    Grid.Row="5"
                    Grid.Column="2"
                    Command="{x:Bind ViewModel.InputDecimalCommand}"
                    Content="."
                    Style="{StaticResource NumberButtonStyle}" />
                <Button
                    x:Name="BtnEqual"
                    Grid.Row="5"
                    Grid.Column="3"
                    Command="{x:Bind ViewModel.CalculateCommand}"
                    Content="&#xe94e;"
                    FontFamily="Segoe Fluent Icons"
                    Style="{StaticResource AccentButtonStyle}" />
            </Grid>
        </Grid>
    </Grid>
</Page>