<Page
    x:Class="Lamina.Views.DyNamoPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Lamina.Views"
    Background="Transparent">

    <Grid Background="Transparent">
        <ScrollViewer VerticalScrollBarVisibility="Hidden" VerticalScrollMode="Auto">
            <StackPanel
                x:Name="ControlStack"
                MaxWidth="380"
                Margin="0,0,0,0"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Spacing="16">

                <InfoBar
                    x:Name="FormulaBar"
                    Title="Formula"
                    IsClosable="False"
                    IsIconVisible="True"
                    Severity="Informational" />

                <ItemsControl x:Name="InputList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="local:InputItem">
                            <NumberBox
                                Width="300"
                                Margin="0,0,0,12"
                                Header="{Binding Header}"
                                Loaded="NumberBox_Loaded"
                                PlaceholderText="{Binding Placeholder}"
                                SpinButtonPlacementMode="Compact"
                                Tag="{Binding Key}" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Button
                    x:Name="CalculateBtn"
                    Height="40"
                    Padding="40,0"
                    HorizontalAlignment="Center"
                    Click="Calculate_Click"
                    Content="Calculate"
                    CornerRadius="8"
                    Style="{StaticResource AccentButtonStyle}">
                    <Button.KeyboardAccelerators>
                        <KeyboardAccelerator Key="Enter" />
                    </Button.KeyboardAccelerators>
                </Button>
            </StackPanel>
        </ScrollViewer>

        <ContentDialog
            x:Name="ResultDialog"
            Title="Result"
            CornerRadius="8"
            DefaultButton="Primary"
            PrimaryButtonText="Close">
            <StackPanel Spacing="4">
                <TextBlock
                    x:Name="ResultLabel"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Style="{StaticResource CaptionTextBlockStyle}" />
                <TextBlock
                    x:Name="ResultValueText"
                    FontSize="28"
                    FontWeight="SemiBold"
                    TextWrapping="Wrap" />
            </StackPanel>
        </ContentDialog>
    </Grid>
</Page>