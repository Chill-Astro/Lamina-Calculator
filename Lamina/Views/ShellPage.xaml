<Page
    x:Class="Lamina.Views.ShellPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="using:Lamina.Behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:helpers="using:Lamina.Helpers"
    xmlns:i="using:Microsoft.Xaml.Interactivity"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{x:Null}"
    Loaded="OnLoaded"
    mc:Ignorable="d">
    <Page.Transitions>
        <TransitionCollection>
            <EntranceThemeTransition />
        </TransitionCollection>
    </Page.Transitions>
    <Page.Resources>
        <FontFamily x:Key="Lamina_Icons">ms-appx:///Assets/Fonts/Lamina_Fonts.ttf#Lamina_Fonts</FontFamily>
    </Page.Resources>
    <Grid Background="Transparent">
        <Grid
            x:Name="AppTitleBar"
            Height="{Binding ElementName=NavigationViewControl, Path=CompactPaneLength}"
            VerticalAlignment="Top"
            Canvas.ZIndex="1"
            IsHitTestVisible="True">
            <Image
                Width="16"
                Height="16"
                HorizontalAlignment="Left"
                Source="/Assets/WindowIcon.ico" />
            <TextBlock
                x:Name="AppTitleBarText"
                Margin="28,0,0,0"
                VerticalAlignment="Center"
                Style="{StaticResource CaptionTextBlockStyle}"
                TextWrapping="NoWrap" />
        </Grid>
        <NavigationView
            x:Name="NavigationViewControl"
            Canvas.ZIndex="0"
            DisplayModeChanged="NavigationViewControl_DisplayModeChanged"
            ExpandedModeThresholdWidth="600"
            Header="{x:Null}"
            IsBackButtonVisible="Auto"
            IsBackEnabled="{x:Bind ViewModel.IsBackEnabled, Mode=OneWay}"
            IsSettingsVisible="True"
            OpenPaneLength="280"
            SelectedItem="{x:Bind ViewModel.Selected, Mode=OneWay}">
            <NavigationView.Background>
                <AcrylicBrush
                    FallbackColor="{ThemeResource SystemChromeLowColor}"
                    Opacity="0.0"
                    TintColor="{ThemeResource SystemChromeLowColor}" />
            </NavigationView.Background>
            <NavigationView.MenuItems>
                <NavigationViewItemHeader Content="Calculators" />
                <NavigationViewItem x:Uid="Shell_Calculator" helpers:NavigationHelper.NavigateTo="Lamina.ViewModels.CalculatorViewModel">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="{StaticResource Lamina_Icons}" Glyph="&#xe230;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Uid="Shell_DateCalculator" helpers:NavigationHelper.NavigateTo="Lamina.ViewModels.DateCalculatorViewModel">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="{StaticResource Lamina_Icons}" Glyph="&#xe231;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItemHeader Content="Converters" />
                <NavigationViewItem x:Uid="Shell_BaseConverter" helpers:NavigationHelper.NavigateTo="Lamina.ViewModels.BaseConverterViewModel">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="{StaticResource Lamina_Icons}" Glyph="&#xe232;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Uid="Shell_UnitConverter" helpers:NavigationHelper.NavigateTo="Lamina.ViewModels.UnitConverterViewModel">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="{StaticResource Lamina_Icons}" Glyph="&#xe233;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Uid="Shell_Currency" helpers:NavigationHelper.NavigateTo="Lamina.ViewModels.CurrencyViewModel">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="{StaticResource Lamina_Icons}" Glyph="&#xE234;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItemHeader Content="Mensuration" />
                <NavigationViewItem x:Uid="Shell_HF" helpers:NavigationHelper.NavigateTo="Lamina.ViewModels.HFViewModel">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="{StaticResource Lamina_Icons}" Glyph="&#xe235;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Uid="Shell_Perimeter" helpers:NavigationHelper.NavigateTo="Lamina.ViewModels.PerimeterViewModel">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="{StaticResource Lamina_Icons}" Glyph="&#xe236;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Uid="Shell_Area" helpers:NavigationHelper.NavigateTo="Lamina.ViewModels.AreaViewModel">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="{StaticResource Lamina_Icons}" Glyph="&#xe237;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Uid="Shell_Volume" helpers:NavigationHelper.NavigateTo="Lamina.ViewModels.VolumeViewModel">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="{StaticResource Lamina_Icons}" Glyph="&#xe238;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Uid="Shell_SurfaceArea" helpers:NavigationHelper.NavigateTo="Lamina.ViewModels.SurfaceAreaViewModel">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="{StaticResource Lamina_Icons}" Glyph="&#xe239;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Uid="Shell_CSurfaceArea" helpers:NavigationHelper.NavigateTo="Lamina.ViewModels.CSurfaceAreaViewModel">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="{StaticResource Lamina_Icons}" Glyph="&#xe240;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Uid="Shell_Diagonal" helpers:NavigationHelper.NavigateTo="Lamina.ViewModels.DiagonalViewModel">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="{StaticResource Lamina_Icons}" Glyph="&#xe241;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItemHeader Content="Algebra" />
                <NavigationViewItem x:Uid="Shell_QuadEqn" helpers:NavigationHelper.NavigateTo="Lamina.ViewModels.QuadEqnViewModel">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="{StaticResource Lamina_Icons}" Glyph="&#xe242;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItemHeader Content="Finance" />
                <NavigationViewItem x:Uid="Shell_FinanceCalculator" helpers:NavigationHelper.NavigateTo="Lamina.ViewModels.FinanceCalculatorViewModel">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="{StaticResource Lamina_Icons}" Glyph="&#xe243;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>
            <i:Interaction.Behaviors>
                <behaviors:NavigationViewHeaderBehavior DefaultHeader="{x:Bind ((ContentControl)ViewModel.Selected).Content, Mode=OneWay}">
                    <behaviors:NavigationViewHeaderBehavior.DefaultHeaderTemplate>
                        <DataTemplate>
                            <Grid />
                        </DataTemplate>
                    </behaviors:NavigationViewHeaderBehavior.DefaultHeaderTemplate>
                </behaviors:NavigationViewHeaderBehavior>
            </i:Interaction.Behaviors>
            <Grid Margin="5">
                <Frame x:Name="NavigationFrame" />
            </Grid>
        </NavigationView>
    </Grid>
</Page>
